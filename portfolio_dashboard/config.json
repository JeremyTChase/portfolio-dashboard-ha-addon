{
  "name": "Portfolio Dashboard",
  "version": "0.9.0",
  "slug": "portfolio_dashboard",
  "description": "Portfolio monitoring dashboard. Displays Freetrade SIP & ISA positions, risk metrics, and market data. Agent tasks handled by NemoClaw.",
  "url": "https://github.com/JeremyTChase/portfolio-dashboard-ha-addon",
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "host_network": true,
  "hassio_api": false,
  "homeassistant_api": false,
  "map": ["config:rw", "share:rw"],
  "ports": {
    "8501/tcp": 8501
  },
  "ports_description": {
    "8501/tcp": "Streamlit Dashboard"
  },
  "environment": {
    "TZ": "{timezone}"
  },
  "options": {
    "timezone": "Europe/London"
  },
  "schema": {
    "timezone": "str"
  }
}
