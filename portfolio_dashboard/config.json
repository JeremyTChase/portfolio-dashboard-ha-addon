{
  "name": "Portfolio Dashboard",
  "version": "0.7.0",
  "slug": "portfolio_dashboard",
  "description": "GPU-optimised portfolio monitoring with AI agent. Tracks Freetrade SIP & ISA positions, risk metrics, macro indicators, and market news.",
  "url": "https://github.com/JeremyTChase/portfolio-dashboard-ha-addon",
  "arch": ["aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "host_network": true,
  "hassio_api": false,
  "homeassistant_api": false,
  "map": ["config:rw", "share:rw"],
  "ports": {
    "8501/tcp": 8501
  },
  "ports_description": {
    "8501/tcp": "Streamlit Dashboard"
  },
  "environment": {
    "TZ": "{timezone}"
  },
  "options": {
    "vllm_base_url": "http://192.168.6.241:8000/v1",
    "vllm_model": "nvidia/Qwen3-Next-80B-A3B-Instruct-NVFP4",
    "timezone": "Europe/London",
    "price_update_interval": 15,
    "daily_analysis_time": "07:30",
    "weekly_review_day": "saturday",
    "weekly_review_time": "09:00"
  },
  "schema": {
    "vllm_base_url": "url",
    "vllm_model": "str",
    "timezone": "str",
    "price_update_interval": "int(5,60)",
    "daily_analysis_time": "match(^[0-2][0-9]:[0-5][0-9]$)",
    "weekly_review_day": "list(monday|tuesday|wednesday|thursday|friday|saturday|sunday)",
    "weekly_review_time": "match(^[0-2][0-9]:[0-5][0-9]$)"
  }
}
